{% extends 'layout.twig' %}

{% block title %}{{ t('admin.order_detail') }} #{{ order.id }} — {{ t('admin.title') }}{% endblock %}

{% block content %}
    <a href="/admin/richieste" class="text-sm underline text-neutral-500 hover:text-neutral-900">← {{ t('admin.back') }}</a>
    {% set status = order.status ?? 'pending' %}
    <div class="flex flex-wrap items-center gap-3 mt-2 mb-6">
        <h1 class="text-2xl font-bold">{{ t('admin.order_detail') }} #{{ order.id }}</h1>
        <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-bold uppercase border
            {{ status == 'confirmed' ? 'bg-emerald-50 border-emerald-200 text-emerald-700'
             : status == 'cancelled' ? 'bg-red-50 border-red-200 text-red-700'
             : 'bg-amber-50 border-amber-200 text-amber-800' }}">
            {{ t('order_status.' ~ status) }}
        </span>
    </div>

    <div class="grid lg:grid-cols-3 gap-5 items-start">
        <div class="lg:col-span-2 bg-white rounded-xl border border-neutral-200 overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-neutral-50 text-neutral-500 text-left">
                        <th class="px-3 py-2.5 font-medium">SKU</th>
                        <th class="px-3 py-2.5 font-medium">Prodotto</th>
                        <th class="px-3 py-2.5 font-medium">EU/US</th>
                        <th class="px-3 py-2.5 font-medium">Barcode</th>
                        <th class="px-3 py-2.5 font-medium text-right">Qty</th>
                        <th class="px-3 py-2.5 font-medium text-right">Prezzo</th>
                        <th class="px-3 py-2.5 font-medium text-right">Subtotale</th>
                        <th class="px-3 py-2.5 font-medium text-right">{{ t('admin.cost') }}</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-neutral-100">
                    {% for line in lines %}
                        <tr>
                            <td class="px-3 py-2 font-mono text-xs">{{ line.sku }}</td>
                            <td class="px-3 py-2">{{ line.name }}</td>
                            <td class="px-3 py-2 whitespace-nowrap">{{ line.size_eu }}{% if line.size_us %} / {{ line.size_us }}{% endif %}</td>
                            <td class="px-3 py-2 font-mono text-xs">{{ line.barcode }}</td>
                            <td class="px-3 py-2 text-right">{{ line.qty }}</td>
                            <td class="px-3 py-2 text-right whitespace-nowrap">{{ line.unit_price|eur }}</td>
                            <td class="px-3 py-2 text-right font-semibold whitespace-nowrap">{{ line.subtotal|eur }}</td>
                            <td class="px-3 py-2 text-right text-neutral-500 whitespace-nowrap">{{ line.offer_price ? line.offer_price|eur : '—' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <aside class="space-y-4">
            <div class="bg-white rounded-xl border border-neutral-200 p-5 text-sm space-y-2">
                <p><span class="text-neutral-500">{{ t('admin.date') }}:</span> {{ order.created_at }}</p>
                <p><span class="text-neutral-500">{{ t('admin.customer') }}:</span> <strong>{{ order.customer_name }}</strong>{% if order.company %} ({{ order.company }}){% endif %}</p>
                <p><span class="text-neutral-500">Email:</span> <a class="underline" href="mailto:{{ order.email }}">{{ order.email }}</a></p>
                <p><span class="text-neutral-500">{{ t('contact.phone') }}:</span> {{ order.phone }}</p>
                {% if order.notes %}<p><span class="text-neutral-500">{{ t('order.notes') }}:</span> {{ order.notes }}</p>{% endif %}
                {% if order.address_street %}
                    <p><span class="text-neutral-500">{{ t('admin.shipping_address') }}:</span> {{ order.address_street }}, {{ order.address_zip }} {{ order.address_city }}</p>
                {% endif %}
                <p><span class="text-neutral-500">{{ t('admin.country') }}:</span> <span class="font-bold">{{ order.country_code ?? 'IT' }}</span> — {{ t('country.' ~ (order.country_code ?? 'IT')) }}</p>
                {% if order.vat_number %}<p><span class="text-neutral-500">{{ t('admin.vat_number') }}:</span> <span class="font-mono">{{ order.vat_number }}</span></p>{% endif %}
                {% if order.plan %}<p><span class="text-neutral-500">{{ t('admin.plan_legacy') }}:</span> <span class="uppercase font-bold">{{ order.plan }}</span></p>{% endif %}
                {% if order.locale is defined and order.locale %}<p><span class="text-neutral-500">{{ t('admin.language') }}:</span> <span class="uppercase">{{ order.locale }}</span></p>{% endif %}
                <p class="text-xs text-neutral-400 pt-2">IP {{ order.ip_address }}</p>
            </div>
            <div class="bg-white rounded-xl border border-neutral-200 p-5 text-sm space-y-2">
                <div class="flex justify-between"><span class="text-neutral-500">{{ t('admin.items') }}</span><strong>{{ order.total_items }}</strong></div>
                <div class="flex justify-between"><span class="text-neutral-500">{{ t('admin.total_net') }}</span><strong>{{ order.total_amount|eur }}</strong></div>
                <div class="flex justify-between">
                    <span class="text-neutral-500">{{ t('vat.scheme_short.' ~ (order.vat_scheme ?? 'domestic')) }}{% if (order.vat_rate ?? 0) > 0 %} ({{ order.vat_rate }}%){% endif %}</span>
                    <span>{{ (order.vat_amount ?? '0')|eur }}</span>
                </div>
                <div class="flex justify-between"><span class="text-neutral-500">{{ t('admin.total_gross') }}</span><strong>{{ ((order.total_gross is defined and order.total_gross > 0) ? order.total_gross : order.total_amount)|eur }}</strong></div>
                <div class="flex justify-between border-t border-neutral-100 pt-2"><span class="text-neutral-500">{{ t('admin.cost') }}</span><span>{{ total_cost|eur }}</span></div>
                <div class="flex justify-between"><span class="text-neutral-500">{{ t('admin.margin') }}</span><strong class="text-emerald-600">{{ margin|eur }}</strong></div>
            </div>
            {# ── Ciclo di vita: conferma a pagamento ricevuto / annulla ── #}
            {% if status == 'pending' %}
                <div class="bg-white rounded-xl border border-amber-200 p-5 text-sm space-y-3">
                    <p class="text-amber-800 text-xs">{{ t('admin.pending_hint') }}</p>
                    <a href="/admin/richieste/{{ order.id }}/modifica"
                       class="block text-center rounded-lg border border-neutral-300 font-semibold py-2 hover:bg-neutral-50">
                        {{ t('admin.edit_link') }}
                    </a>
                    <form method="post" action="/admin/richieste/{{ order.id }}/conferma"
                          data-confirm="{{ t('admin.confirm_prompt')|e('html_attr') }}">
                        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                        <button type="submit" class="w-full rounded-lg bg-emerald-600 text-white font-semibold py-2.5 hover:bg-emerald-500">
                            {{ t('admin.confirm_button') }}
                        </button>
                    </form>
                    <form method="post" action="/admin/richieste/{{ order.id }}/annulla"
                          data-confirm="{{ t('admin.cancel_prompt')|e('html_attr') }}">
                        <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                        <button type="submit" class="w-full rounded-lg border border-red-200 text-red-600 font-semibold py-2 hover:bg-red-50">
                            {{ t('admin.cancel_button') }}
                        </button>
                    </form>
                </div>
            {% endif %}

            <div class="bg-white rounded-xl border border-neutral-200 p-5 text-sm space-y-2">
                <div class="flex items-center justify-between gap-2">
                    <span class="text-neutral-500">{{ t('admin.receipt') }}</span>
                    <span class="font-mono text-xs">{{ order.receipt_number ?: t('admin.receipt_on_confirm') }}</span>
                </div>
                {% if order.confirmed_at ?? null %}
                    <p class="text-xs text-neutral-400">{{ t('admin.confirmed_at') }}: {{ order.confirmed_at }}</p>
                {% endif %}
                {% if order.cancelled_at ?? null %}
                    <p class="text-xs text-neutral-400">{{ t('admin.cancelled_at') }}: {{ order.cancelled_at }}</p>
                {% endif %}
                <a href="/admin/richieste/{{ order.id }}/ricevuta.pdf" target="_blank" rel="noopener"
                   class="block text-center rounded-lg border border-neutral-300 font-semibold py-2 hover:bg-neutral-50">
                    {{ t('admin.receipt_download') }}
                </a>
            </div>
            <div class="bg-white rounded-xl border border-neutral-200 p-5 text-xs space-y-1">
                <p class="{{ order.email_admin_sent ? 'text-emerald-600' : 'text-red-600' }}">{{ t('admin.email_admin') }}: {{ order.email_admin_sent ? t('admin.email_sent') : t('admin.email_failed') }}</p>
                <p class="{{ order.email_customer_sent ? 'text-emerald-600' : 'text-red-600' }}">{{ t('admin.email_customer') }}: {{ order.email_customer_sent ? t('admin.email_sent') : t('admin.email_failed') }}</p>
            </div>

            {% if dropship_enabled %}
                <div class="bg-white rounded-xl border border-neutral-200 p-5 text-sm space-y-3">
                    <div class="flex items-center gap-2">
                        <h2 class="font-semibold">{{ t('dropship.card_title') }}</h2>
                        {% if dropship_is_simulation %}
                            <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-800 border border-sky-200 px-2 py-0.5 text-[10px] font-bold uppercase">{{ t('dropship.simulation_badge') }}</span>
                        {% endif %}
                    </div>
                    {% if dropship_orders is empty %}
                        <p class="text-xs text-neutral-500">{{ t('dropship.card_none') }}</p>
                    {% else %}
                        <ul class="space-y-1 text-xs">
                            {% for ds in dropship_orders %}
                                <li>
                                    <a class="underline font-semibold" href="/admin/dropship/{{ ds.id }}">#{{ ds.id }}</a>
                                    — {{ t('dropship.status.' ~ ds.status) }}
                                    {% if ds.mode == 'simulation' %}· {{ t('dropship.simulation_badge') }}{% endif %}
                                    · {{ ds.created_at }}
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                    <a href="/admin/richieste/{{ order.id }}/dropship"
                       class="block text-center rounded-lg bg-neutral-900 text-white font-semibold py-2 hover:bg-neutral-700">
                        {{ t('dropship.card_start') }}
                    </a>
                </div>
            {% endif %}
        </aside>
    </div>
{% endblock %}
