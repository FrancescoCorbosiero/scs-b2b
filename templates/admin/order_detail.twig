{% extends 'layout.twig' %}

{% block title %}{{ t('admin.order_detail') }} #{{ order.id }} — {{ t('admin.title') }}{% endblock %}

{% block content %}
    <a href="/admin/richieste" class="text-sm underline text-neutral-500 hover:text-neutral-900">← {{ t('admin.back') }}</a>
    <h1 class="text-2xl font-bold mt-2 mb-6">{{ t('admin.order_detail') }} #{{ order.id }}</h1>

    <div class="grid lg:grid-cols-3 gap-5 items-start">
        <div class="lg:col-span-2 bg-white rounded-xl border border-neutral-200 overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-neutral-50 text-neutral-500 text-left">
                        <th class="px-3 py-2.5 font-medium">SKU</th>
                        <th class="px-3 py-2.5 font-medium">Prodotto</th>
                        <th class="px-3 py-2.5 font-medium">EU/US</th>
                        <th class="px-3 py-2.5 font-medium">Barcode</th>
                        <th class="px-3 py-2.5 font-medium text-right">Qty</th>
                        <th class="px-3 py-2.5 font-medium text-right">Prezzo</th>
                        <th class="px-3 py-2.5 font-medium text-right">Subtotale</th>
                        <th class="px-3 py-2.5 font-medium text-right">{{ t('admin.cost') }}</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-neutral-100">
                    {% for line in lines %}
                        <tr>
                            <td class="px-3 py-2 font-mono text-xs">{{ line.sku }}</td>
                            <td class="px-3 py-2">{{ line.name }}</td>
                            <td class="px-3 py-2 whitespace-nowrap">{{ line.size_eu }}{% if line.size_us %} / {{ line.size_us }}{% endif %}</td>
                            <td class="px-3 py-2 font-mono text-xs">{{ line.barcode }}</td>
                            <td class="px-3 py-2 text-right">{{ line.qty }}</td>
                            <td class="px-3 py-2 text-right whitespace-nowrap">{{ line.unit_price|eur }}</td>
                            <td class="px-3 py-2 text-right font-semibold whitespace-nowrap">{{ line.subtotal|eur }}</td>
                            <td class="px-3 py-2 text-right text-neutral-500 whitespace-nowrap">{{ line.offer_price ? line.offer_price|eur : '—' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <aside class="space-y-4">
            <div class="bg-white rounded-xl border border-neutral-200 p-5 text-sm space-y-2">
                <p><span class="text-neutral-500">{{ t('admin.date') }}:</span> {{ order.created_at }}</p>
                <p><span class="text-neutral-500">{{ t('admin.customer') }}:</span> <strong>{{ order.customer_name }}</strong>{% if order.company %} ({{ order.company }}){% endif %}</p>
                <p><span class="text-neutral-500">Email:</span> <a class="underline" href="mailto:{{ order.email }}">{{ order.email }}</a></p>
                <p><span class="text-neutral-500">{{ t('contact.phone') }}:</span> {{ order.phone }}</p>
                {% if order.notes %}<p><span class="text-neutral-500">{{ t('order.notes') }}:</span> {{ order.notes }}</p>{% endif %}
                <p><span class="text-neutral-500">{{ t('admin.plan') }}:</span> <span class="uppercase font-bold">{{ order.plan }}</span></p>
                <p class="text-xs text-neutral-400 pt-2">IP {{ order.ip_address }}</p>
            </div>
            <div class="bg-white rounded-xl border border-neutral-200 p-5 text-sm space-y-2">
                <div class="flex justify-between"><span class="text-neutral-500">{{ t('admin.items') }}</span><strong>{{ order.total_items }}</strong></div>
                <div class="flex justify-between"><span class="text-neutral-500">{{ t('admin.total') }}</span><strong>{{ order.total_amount|eur }}</strong></div>
                <div class="flex justify-between"><span class="text-neutral-500">{{ t('admin.cost') }}</span><span>{{ total_cost|eur }}</span></div>
                <div class="flex justify-between border-t border-neutral-100 pt-2"><span class="text-neutral-500">{{ t('admin.margin') }}</span><strong class="text-emerald-600">{{ margin|eur }}</strong></div>
            </div>
            <div class="bg-white rounded-xl border border-neutral-200 p-5 text-xs space-y-1">
                <p class="{{ order.email_admin_sent ? 'text-emerald-600' : 'text-red-600' }}">{{ t('admin.email_admin') }}: {{ order.email_admin_sent ? t('admin.email_sent') : t('admin.email_failed') }}</p>
                <p class="{{ order.email_customer_sent ? 'text-emerald-600' : 'text-red-600' }}">{{ t('admin.email_customer') }}: {{ order.email_customer_sent ? t('admin.email_sent') : t('admin.email_failed') }}</p>
            </div>
        </aside>
    </div>
{% endblock %}
