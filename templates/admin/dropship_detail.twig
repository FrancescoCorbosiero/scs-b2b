{% extends 'layout.twig' %}

{% block title %}{{ t('dropship.detail_title') }} #{{ ds.id }} — {{ t('admin.title') }}{% endblock %}

{% block content %}
    {% if ds.order_request_id %}
        <a href="/admin/richieste/{{ ds.order_request_id }}" class="text-sm underline text-neutral-500 hover:text-neutral-900">← {{ t('dropship.detail_request') }} #{{ ds.order_request_id }}</a>
    {% else %}
        <a href="/admin/richieste" class="text-sm underline text-neutral-500 hover:text-neutral-900">← {{ t('admin.orders') }}</a>
    {% endif %}
    <div class="flex flex-wrap items-center gap-3 mt-2 mb-6">
        <h1 class="text-2xl font-bold">{{ t('dropship.detail_title') }} #{{ ds.id }}</h1>
        {% if ds.mode == 'simulation' %}
            <span class="inline-flex items-center rounded-full bg-sky-100 text-sky-800 border border-sky-200 px-3 py-0.5 text-xs font-bold uppercase">{{ t('dropship.simulation_badge') }}</span>
        {% endif %}
        <span class="inline-flex items-center rounded-full bg-neutral-100 text-neutral-700 border border-neutral-200 px-3 py-0.5 text-xs font-semibold">{{ t('dropship.status.' ~ ds.status) }}</span>
    </div>

    {% if ds.mode == 'simulation' %}
        <div class="mb-4 rounded-lg px-4 py-3 text-sm border bg-sky-50 border-sky-200 text-sky-900">
            {{ t('dropship.simulation_banner') }}
        </div>
    {% endif %}

    <div class="grid lg:grid-cols-3 gap-5 items-start">
        <div class="lg:col-span-2 space-y-5">
            <div class="bg-white rounded-xl border border-neutral-200 overflow-x-auto">
                <h2 class="font-semibold px-5 pt-4">{{ t('dropship.items_title') }}</h2>
                <table class="w-full text-sm mt-3">
                    <thead>
                        <tr class="bg-neutral-50 text-neutral-500 text-left">
                            <th class="px-3 py-2.5 font-medium">SKU</th>
                            <th class="px-3 py-2.5 font-medium">Prodotto</th>
                            <th class="px-3 py-2.5 font-medium">EU/US</th>
                            <th class="px-3 py-2.5 font-medium text-right">{{ t('dropship.col_size_id') }}</th>
                            <th class="px-3 py-2.5 font-medium text-right">Qty</th>
                            <th class="px-3 py-2.5 font-medium text-right">{{ t('admin.cost') }}</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-neutral-100">
                        {% for line in lines %}
                            <tr>
                                <td class="px-3 py-2 font-mono text-xs">{{ line.sku }}</td>
                                <td class="px-3 py-2">{{ line.name }}</td>
                                <td class="px-3 py-2 whitespace-nowrap">{{ line.size_eu }}{% if line.size_us %} / {{ line.size_us }}{% endif %}</td>
                                <td class="px-3 py-2 text-right font-mono text-xs">{{ line.supplier_size_id ?? '—' }}</td>
                                <td class="px-3 py-2 text-right font-semibold">{{ line.qty }}</td>
                                <td class="px-3 py-2 text-right text-neutral-500 whitespace-nowrap">{{ line.offer_price|eur }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="bg-white rounded-xl border border-neutral-200 p-5">
                <h2 class="font-semibold mb-2">{{ t('dropship.payload_title') }}</h2>
                <pre class="text-xs bg-neutral-900 text-neutral-100 rounded-lg p-4 overflow-x-auto">{{ request_json }}</pre>
            </div>

            {% if response_json %}
                <div class="bg-white rounded-xl border border-neutral-200 p-5">
                    <h2 class="font-semibold mb-2">{{ t('dropship.response_title') }}</h2>
                    <pre class="text-xs bg-neutral-900 text-neutral-100 rounded-lg p-4 overflow-x-auto">{{ response_json }}</pre>
                </div>
            {% endif %}
        </div>

        <aside class="space-y-4">
            <div class="bg-white rounded-xl border border-neutral-200 p-5 text-sm space-y-2">
                <p><span class="text-neutral-500">{{ t('admin.date') }}:</span> {{ ds.created_at }}</p>
                <p><span class="text-neutral-500">{{ t('admin.status') }}:</span> <strong>{{ t('dropship.status.' ~ ds.status) }}</strong></p>
                <p><span class="text-neutral-500">{{ t('dropship.vendor_order_id') }}:</span> <span class="font-mono">{{ ds.vendor_order_id ?? '—' }}</span></p>
                <p><span class="text-neutral-500">{{ t('dropship.package_id') }}:</span> <span class="font-mono">{{ ds.dropship_package_id ?? '—' }}</span></p>
                <div class="flex justify-between border-t border-neutral-100 pt-2">
                    <span class="text-neutral-500">{{ t('dropship.wholesale_total') }}</span>
                    <strong>{{ ds.total_price|eur }}</strong>
                </div>
                <p class="text-xs text-neutral-400">{{ t('dropship.wholesale_note') }}</p>
            </div>

            <div class="bg-white rounded-xl border border-neutral-200 p-5 text-sm space-y-2">
                <h2 class="font-semibold">{{ t('dropship.tracking') }}</h2>
                {% if tracking is empty %}
                    <p class="text-neutral-500 text-xs">{{ t('dropship.tracking_none') }}</p>
                {% else %}
                    <ul class="space-y-1">
                        {% for number in tracking %}
                            <li class="font-mono text-xs">{{ number }}</li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>

            <form method="post" action="/admin/dropship/{{ ds.id }}/aggiorna">
                <input type="hidden" name="_csrf" value="{{ csrf_token }}">
                <button type="submit" class="w-full rounded-lg bg-neutral-900 text-white font-semibold py-2.5 hover:bg-neutral-700">
                    {{ t('dropship.refresh_status') }}
                </button>
            </form>
        </aside>
    </div>
{% endblock %}
