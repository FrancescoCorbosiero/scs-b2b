{% extends 'layout.twig' %}

{% block title %}{{ t('admin.sync') }} — {{ t('admin.title') }}{% endblock %}

{% block content %}
    <div class="flex items-center gap-4 mb-6">
        <h1 class="text-2xl font-bold">{{ t('admin.sync') }}</h1>
        <form method="post" action="/admin/sync/run" class="ml-auto">
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
            <button type="submit" class="rounded-lg bg-neutral-900 text-white px-4 py-2 font-semibold hover:bg-neutral-700">
                {{ t('admin.sync_now') }}
            </button>
        </form>
    </div>

    <div class="bg-white rounded-xl border border-neutral-200 overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-neutral-50 text-neutral-500 text-left">
                    <th class="px-4 py-2.5 font-medium">#</th>
                    <th class="px-4 py-2.5 font-medium">{{ t('admin.date') }}</th>
                    <th class="px-4 py-2.5 font-medium">{{ t('admin.status') }}</th>
                    <th class="px-4 py-2.5 font-medium text-right">{{ t('admin.rows_read') }}</th>
                    <th class="px-4 py-2.5 font-medium text-right">{{ t('admin.created') }}</th>
                    <th class="px-4 py-2.5 font-medium text-right">{{ t('admin.updated') }}</th>
                    <th class="px-4 py-2.5 font-medium text-right">{{ t('admin.deactivated') }}</th>
                    <th class="px-4 py-2.5 font-medium">Note</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100">
                {% for log in logs %}
                    <tr>
                        <td class="px-4 py-2.5">{{ log.id }}</td>
                        <td class="px-4 py-2.5 whitespace-nowrap">{{ log.started_at }}{% if log.finished_at %} → {{ log.finished_at }}{% endif %}</td>
                        <td class="px-4 py-2.5">
                            <span class="inline-block rounded-full px-2.5 py-0.5 text-xs font-bold {{ log.status == 'ok' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700' }}">
                                {{ log.status|upper }}
                            </span>
                        </td>
                        <td class="px-4 py-2.5 text-right">{{ log.rows_read }}</td>
                        <td class="px-4 py-2.5 text-right">{{ log.products_created }}</td>
                        <td class="px-4 py-2.5 text-right">{{ log.products_updated }}</td>
                        <td class="px-4 py-2.5 text-right">{{ log.products_deactivated }}</td>
                        <td class="px-4 py-2.5 text-xs text-neutral-500 max-w-xs truncate" title="{{ log.message }}">{{ log.message }}</td>
                    </tr>
                {% else %}
                    <tr><td colspan="8" class="px-4 py-8 text-center text-neutral-400">{{ t('admin.sync_never') }}</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
