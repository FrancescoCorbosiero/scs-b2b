{% extends 'layout.twig' %}

{% block title %}{{ t('contact.title') }} — {{ t('app.title') }}{% endblock %}

{% block content %}
    <h1 class="text-2xl font-bold mb-6">{{ t('contact.title') }}</h1>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl">
        <div class="bg-white rounded-xl border border-neutral-200 p-5">
            <h2 class="text-sm text-neutral-500 mb-1">{{ t('contact.email') }}</h2>
            <p class="font-semibold break-all mb-3">{{ contact.email }}</p>
            <a href="mailto:{{ contact.email }}" class="inline-block rounded-lg bg-neutral-900 text-white text-sm px-4 py-2 font-semibold hover:bg-neutral-700">{{ t('contact.write_us') }}</a>
        </div>
        <div class="bg-white rounded-xl border border-neutral-200 p-5">
            <h2 class="text-sm text-neutral-500 mb-1">{{ t('contact.phone') }}</h2>
            <p class="font-semibold mb-3">{{ contact.phone }}</p>
            <a href="tel:{{ contact.phone|replace({' ': ''}) }}" class="inline-block rounded-lg bg-neutral-900 text-white text-sm px-4 py-2 font-semibold hover:bg-neutral-700">{{ t('contact.call_us') }}</a>
        </div>
        {% if contact.whatsapp_link %}
            <div class="bg-white rounded-xl border border-neutral-200 p-5">
                <h2 class="text-sm text-neutral-500 mb-1">{{ t('contact.whatsapp') }}</h2>
                <p class="font-semibold mb-3">{{ contact.whatsapp }}</p>
                <a href="{{ contact.whatsapp_link }}" rel="noopener" class="inline-block rounded-lg bg-emerald-600 text-white text-sm px-4 py-2 font-semibold hover:bg-emerald-500">{{ t('contact.chat_whatsapp') }}</a>
            </div>
        {% endif %}
    </div>

    <div class="mt-6 max-w-4xl bg-white rounded-xl border border-neutral-200 p-5 text-sm text-neutral-600 space-y-1">
        <p class="font-semibold text-neutral-900">{{ contact.company }}</p>
        <p>{{ t('contact.address') }}: {{ contact.address }}</p>
        <p>{{ contact.vat }}</p>
        <a href="{{ contact.main_site }}" rel="noopener" class="inline-block underline hover:text-neutral-900 mt-2">{{ t('contact.main_site') }}</a>
    </div>
{% endblock %}
