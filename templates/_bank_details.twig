{# Coordinate bancarie per il bonifico (global `bank` da View). Con IBAN vuoto
   si mostra l'invito a contattarci. `reference` opzionale = causale consigliata. #}
{% if bank.iban %}
    <dl class="rounded-lg bg-neutral-50 border border-neutral-200 p-4 text-sm space-y-1.5">
        {% if bank.holder %}
            <div class="flex justify-between gap-3"><dt class="text-neutral-500">{{ t('payment.holder') }}</dt><dd class="font-semibold text-right">{{ bank.holder }}</dd></div>
        {% endif %}
        {% if bank.name %}
            <div class="flex justify-between gap-3"><dt class="text-neutral-500">{{ t('payment.bank') }}</dt><dd class="font-semibold text-right">{{ bank.name }}</dd></div>
        {% endif %}
        <div class="flex justify-between gap-3 items-center">
            <dt class="text-neutral-500">IBAN</dt>
            <dd class="font-mono font-semibold text-right break-all">
                {{ bank.iban }}
                <button type="button" data-copy="{{ bank.iban }}" title="{{ t('payment.copy_iban') }}"
                        class="ml-1 p-1 rounded hover:bg-neutral-200 text-neutral-400 hover:text-neutral-700 align-middle">
                    <svg class="w-3.5 h-3.5 inline" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5"/></svg>
                </button>
            </dd>
        </div>
        {% if bank.bic %}
            <div class="flex justify-between gap-3"><dt class="text-neutral-500">BIC/SWIFT</dt><dd class="font-mono font-semibold text-right">{{ bank.bic }}</dd></div>
        {% endif %}
        {% if reference %}
            <div class="flex justify-between gap-3 border-t border-neutral-200 pt-2"><dt class="text-neutral-500">{{ t('payment.reference') }}</dt><dd class="font-semibold text-right">{{ reference }}</dd></div>
        {% endif %}
    </dl>
{% else %}
    <p class="rounded-lg bg-neutral-50 border border-neutral-200 p-4 text-sm text-neutral-600">
        {{ t('payment.details_missing') }}
    </p>
{% endif %}
