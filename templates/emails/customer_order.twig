{# Email cliente alla RICHIESTA (locale del cliente): istruzioni di pagamento
   via bonifico. L'ordine si conferma SOLO all'arrivo del pagamento: la
   ricevuta pro-forma arriva con l'email di conferma (customer_confirmed).
   MAI costi fornitore o margini qui (il dato non arriva proprio al template). #}
<div style="font-family: Arial, Helvetica, sans-serif; color: #171717; max-width: 680px;">
    <h1 style="font-size: 20px;">{{ t('email.customer_title', {id: order.id}) }}</h1>
    <p>{{ t('email.customer_greeting', {name: order.customer_name}) }}</p>
    <p>{{ t('email.customer_body') }}</p>
    <p style="background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; padding: 10px 12px;">
        <strong>{{ t('email.payment_required_notice') }}</strong>
    </p>

    <table cellpadding="6" cellspacing="0" border="1" style="border-collapse: collapse; border-color: #d4d4d4; font-size: 13px; margin-top: 12px; width: 100%;">
        <thead>
            <tr style="background: #f5f5f5;">
                <th align="left">SKU</th>
                <th align="left">{{ t('email.col_product') }}</th>
                <th align="left">{{ t('email.col_size_eu') }}</th>
                <th align="left">{{ t('email.col_size_us') }}</th>
                <th align="right">{{ t('email.col_qty') }}</th>
                <th align="right">{{ t('email.col_unit_price') }}</th>
                <th align="right">{{ t('email.col_subtotal') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for line in order.lines %}
                <tr>
                    <td>{{ line.sku }}</td>
                    <td>{{ line.name }}</td>
                    <td>{{ line.size_eu }}</td>
                    <td>{{ line.size_us }}</td>
                    <td align="right">{{ line.qty }}</td>
                    <td align="right">{{ line.unit_price|eur }}</td>
                    <td align="right"><strong>{{ line.subtotal|eur }}</strong></td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    <table cellpadding="4" cellspacing="0" style="font-size: 14px; margin-top: 14px; margin-left: auto;">
        <tr>
            <td style="color: #525252;">{{ t('email.total_items') }}</td>
            <td align="right"><strong>{{ order.total_items }}</strong></td>
        </tr>
        <tr>
            <td style="color: #525252;">{{ t('email.total_net') }}</td>
            <td align="right"><strong>{{ order.total_amount|eur }}</strong></td>
        </tr>
        <tr>
            <td style="color: #525252;">
                {% if order.vat_scheme == 'reverse_charge' %}{{ t('vat.label_reverse') }}
                {% elseif order.vat_scheme == 'export' %}{{ t('vat.label_export') }}
                {% else %}{{ t('vat.label_rate', {rate: order.vat_rate}) }}{% endif %}
            </td>
            <td align="right">{{ order.vat_amount|eur }}</td>
        </tr>
        <tr>
            <td style="color: #171717; border-top: 1px solid #d4d4d4;"><strong>{{ t('email.total_to_pay') }}</strong></td>
            <td align="right" style="border-top: 1px solid #d4d4d4;"><strong>{{ order.total_gross|eur }}</strong></td>
        </tr>
    </table>

    <h2 style="font-size: 15px; margin-top: 18px;">{{ t('email.payment_title') }}</h2>
    <p style="font-size: 13px; color: #525252;">{{ t('email.payment_intro') }}</p>
    {% if bank.iban %}
        <table cellpadding="5" cellspacing="0" border="1" style="border-collapse: collapse; border-color: #d4d4d4; font-size: 13px; width: 100%;">
            {% if bank.holder %}<tr><td style="color: #525252; width: 40%;">{{ t('payment.holder') }}</td><td><strong>{{ bank.holder }}</strong></td></tr>{% endif %}
            {% if bank.name %}<tr><td style="color: #525252;">{{ t('payment.bank') }}</td><td><strong>{{ bank.name }}</strong></td></tr>{% endif %}
            <tr><td style="color: #525252;">IBAN</td><td><strong style="font-family: monospace;">{{ bank.iban }}</strong></td></tr>
            {% if bank.bic %}<tr><td style="color: #525252;">BIC/SWIFT</td><td><strong style="font-family: monospace;">{{ bank.bic }}</strong></td></tr>{% endif %}
            <tr><td style="color: #525252;">{{ t('payment.amount') }}</td><td><strong>{{ order.total_gross|eur }}</strong></td></tr>
            <tr><td style="color: #525252;">{{ t('payment.reference') }}</td><td><strong>{{ t('payment.reference_value', {id: order.id}) }}</strong></td></tr>
        </table>
    {% else %}
        <p style="font-size: 13px; background: #fafafa; border: 1px solid #e5e5e5; border-radius: 8px; padding: 10px 12px;">{{ t('payment.details_missing') }}</p>
    {% endif %}
    <p style="font-size: 12px; color: #525252;">{{ t('email.payment_after') }}</p>

    {% if order.vat_scheme == 'reverse_charge' %}
        <p style="color: #525252; font-size: 12px;">{{ t('vat.note_reverse') }}</p>
    {% elseif order.vat_scheme == 'export' %}
        <p style="color: #525252; font-size: 12px;">{{ t('vat.note_export') }}</p>
    {% endif %}
    <p style="color: #525252; font-size: 12px;">{{ t('email.customer_vat_disclaimer', {country: t('country.' ~ order.country_code)}) }}</p>

    <p style="margin-top: 18px;">{{ t('email.customer_closing') }}</p>
    <p style="margin: 4px 0;"><strong>{{ company_name }}</strong></p>

    <p style="color: #525252; font-size: 13px; margin-top: 18px;">
        {{ t('email.customer_contacts') }}: {{ contact_email }} · {{ contact_phone }}{% if contact_whatsapp %} · WhatsApp {{ contact_whatsapp }}{% endif %}
    </p>
</div>
