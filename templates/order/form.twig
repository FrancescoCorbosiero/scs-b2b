{% extends 'layout.twig' %}

{% block title %}{{ t('order.title') }} — {{ t('app.title') }}{% endblock %}

{% block content %}
    <h1 class="text-2xl font-bold mb-4">{{ t('order.title') }}</h1>

    <div class="lg:grid lg:grid-cols-3 lg:gap-6 lg:items-start" x-data="{ payOpen: false }">
        <form method="post" action="/richiesta-ordine" data-order-form data-countdown-seconds="15"
              class="lg:col-span-2 bg-white rounded-xl border border-neutral-200 p-5 sm:p-6 space-y-4">
            <p class="text-sm text-neutral-500">{{ t('order.intro') }}</p>
            <input type="hidden" name="_csrf" value="{{ csrf_token }}">
            {# honeypot antispam: invisibile agli utenti, i bot lo compilano #}
            <div class="hidden" aria-hidden="true">
                <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off"></label>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
                <div>
                    <label for="o-name" class="block text-sm font-medium mb-1">{{ t('order.name') }}</label>
                    <input type="text" id="o-name" name="customer_name" required maxlength="128" value="{{ old.customer_name ?? '' }}"
                           class="w-full rounded-lg border-neutral-300 focus:border-amber-500 focus:ring-amber-500">
                </div>
                <div>
                    <label for="o-company" class="block text-sm font-medium mb-1">{{ t('order.company') }}</label>
                    <input type="text" id="o-company" name="company" maxlength="128" value="{{ old.company ?? '' }}"
                           class="w-full rounded-lg border-neutral-300 focus:border-amber-500 focus:ring-amber-500">
                </div>
                <div>
                    <label for="o-email" class="block text-sm font-medium mb-1">{{ t('order.email') }}</label>
                    <input type="email" id="o-email" name="email" required maxlength="255" value="{{ old.email ?? '' }}"
                           class="w-full rounded-lg border-neutral-300 focus:border-amber-500 focus:ring-amber-500">
                </div>
                <div>
                    <label for="o-phone" class="block text-sm font-medium mb-1">{{ t('order.phone') }}</label>
                    <input type="tel" id="o-phone" name="phone" required maxlength="32" value="{{ old.phone ?? '' }}"
                           class="w-full rounded-lg border-neutral-300 focus:border-amber-500 focus:ring-amber-500">
                </div>
                {# indirizzo di spedizione: serve anche all'ordine dropship verso il fornitore #}
                <div class="sm:col-span-2">
                    <label for="o-street" class="block text-sm font-medium mb-1">{{ t('order.street') }}</label>
                    <input type="text" id="o-street" name="address_street" required maxlength="255" value="{{ old.address_street ?? '' }}"
                           class="w-full rounded-lg border-neutral-300 focus:border-amber-500 focus:ring-amber-500">
                </div>
                <div>
                    <label for="o-city" class="block text-sm font-medium mb-1">{{ t('order.city') }}</label>
                    <input type="text" id="o-city" name="address_city" required maxlength="128" value="{{ old.address_city ?? '' }}"
                           class="w-full rounded-lg border-neutral-300 focus:border-amber-500 focus:ring-amber-500">
                </div>
                <div>
                    <label for="o-zip" class="block text-sm font-medium mb-1">{{ t('order.zip') }}</label>
                    <input type="text" id="o-zip" name="address_zip" required maxlength="16" value="{{ old.address_zip ?? '' }}"
                           class="w-full rounded-lg border-neutral-300 focus:border-amber-500 focus:ring-amber-500">
                </div>
                <div>
                    <label for="o-country" class="block text-sm font-medium mb-1">{{ t('order.country') }}</label>
                    <select id="o-country" name="country" required
                            class="w-full rounded-lg border-neutral-300 focus:border-amber-500 focus:ring-amber-500">
                        {% set selected_country = old.country ?? country %}
                        {% for c in countries %}
                            <option value="{{ c.code }}" {{ selected_country == c.code ? 'selected' }}>{{ c.name }} ({{ c.code }})</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label for="o-vat-number" class="block text-sm font-medium mb-1">{{ t('order.vat_number') }}</label>
                    <input type="text" id="o-vat-number" name="vat_number" maxlength="32" value="{{ old.vat_number ?? '' }}"
                           placeholder="{{ t('order.vat_number_placeholder') }}"
                           class="w-full rounded-lg border-neutral-300 focus:border-amber-500 focus:ring-amber-500">
                    <p class="mt-1 text-xs text-neutral-400">{{ t('order.vat_number_hint') }}</p>
                </div>
            </div>
            <div>
                <label for="o-notes" class="block text-sm font-medium mb-1">{{ t('order.notes') }}</label>
                <textarea id="o-notes" name="notes" rows="4" maxlength="2000"
                          class="w-full rounded-lg border-neutral-300 focus:border-amber-500 focus:ring-amber-500">{{ old.notes ?? '' }}</textarea>
            </div>
            {# pagamento: unico canale = bonifico; l'ordine si conferma SOLO all'arrivo #}
            <div class="rounded-lg bg-amber-50 border border-amber-200 px-4 py-3 text-sm text-amber-900">
                {{ t('order.payment_notice') }}
                <button type="button" @click="payOpen = true" class="underline font-semibold hover:text-amber-700">
                    {{ t('order.payment_details_link') }}
                </button>
            </div>

            {# finestra di ripensamento: 15s di countdown PRIMA dell'invio reale
               (finché non scade non parte nulla: né email né ordine al fornitore) #}
            <div data-submit-countdown class="hidden rounded-lg bg-neutral-900 text-white px-4 py-3 flex flex-wrap items-center gap-3"
                 data-text-template="{{ t('order.countdown_text')|e('html_attr') }}">
                <svg class="w-5 h-5 animate-spin shrink-0" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"/></svg>
                <span data-countdown-text class="text-sm font-medium flex-1"></span>
                <button type="button" data-countdown-cancel
                        class="rounded-lg bg-white text-neutral-900 px-4 py-1.5 text-sm font-bold hover:bg-neutral-200">
                    {{ t('order.countdown_cancel') }}
                </button>
            </div>

            <button type="submit" data-order-submit class="rounded-lg bg-neutral-900 text-white px-6 py-2.5 font-semibold hover:bg-neutral-700">
                {{ t('order.submit') }}
            </button>
        </form>

        <aside class="mt-6 lg:mt-0">
            <div class="bg-white rounded-xl border border-neutral-200 p-5"
                 data-vat-preview
                 data-countries="{{ countries|json_encode|e('html_attr') }}"
                 data-net="{{ cart.total_amount }}"
                 data-label-domestic="{{ t('vat.label_rate')|e('html_attr') }}"
                 data-label-eu="{{ t('vat.label_rate')|e('html_attr') }}"
                 data-label-reverse="{{ t('vat.label_reverse')|e('html_attr') }}"
                 data-label-export="{{ t('vat.label_export')|e('html_attr') }}"
                 data-hint-domestic="{{ t('vat.hint_domestic')|e('html_attr') }}"
                 data-hint-eu="{{ t('vat.hint_eu')|e('html_attr') }}"
                 data-hint-reverse="{{ t('vat.hint_reverse')|e('html_attr') }}"
                 data-hint-export="{{ t('vat.hint_export')|e('html_attr') }}">
                <h2 class="font-bold mb-3">{{ t('order.summary_title') }}</h2>
                <ul class="divide-y divide-neutral-100 text-sm">
                    {% for product in cart.products %}
                        {% for size in product.sizes %}
                            {% if size.qty > 0 %}
                                <li class="py-2 flex justify-between gap-2">
                                    <span class="min-w-0">
                                        <span class="font-mono text-xs text-neutral-500">{{ product.sku }}</span>
                                        {{ t('cart.size') }} {{ size_system == 'us' and size.size_us ? size.size_us : size.size_eu }} × {{ size.qty }}
                                    </span>
                                    <span class="font-medium whitespace-nowrap">{{ size.row_total|eur }}</span>
                                </li>
                            {% endif %}
                        {% endfor %}
                    {% endfor %}
                </ul>
                <div class="border-t border-neutral-200 mt-2 pt-3 space-y-1.5 text-sm">
                    <div class="flex justify-between">
                        <span class="text-neutral-500">{{ t('cart.total_net') }}</span>
                        <span class="font-semibold">{{ cart.total_amount|eur }}</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-neutral-500" data-vat-label>—</span>
                        <span data-vat-amount>—</span>
                    </div>
                    <div class="flex justify-between font-bold border-t border-neutral-200 pt-2">
                        <span>{{ t('order.total_estimated') }}</span>
                        <span data-vat-gross>{{ cart.total_amount|eur }}</span>
                    </div>
                </div>
                <p class="text-xs text-neutral-400 mt-2" data-vat-hint></p>
                <p class="text-xs text-neutral-400 mt-2">{{ t('cart.total_items') }}: {{ cart.total_items }}</p>
            </div>
        </aside>

        {# ── Modal pagamento: come funziona il bonifico ── #}
        <div x-show="payOpen" x-cloak class="fixed inset-0 z-50 flex items-center justify-center p-4"
             role="dialog" aria-modal="true" aria-labelledby="pay-modal-title" @keydown.escape.window="payOpen = false">
            <div class="absolute inset-0 bg-neutral-900/60" @click="payOpen = false"></div>
            <div class="relative bg-white rounded-2xl shadow-xl max-w-lg w-full p-6 space-y-4">
                <div class="flex items-start justify-between gap-4">
                    <h2 id="pay-modal-title" class="text-lg font-bold">{{ t('payment.modal_title') }}</h2>
                    <button type="button" @click="payOpen = false" class="p-1 rounded-md hover:bg-neutral-100 text-neutral-400 hover:text-neutral-700" aria-label="{{ t('payment.modal_close') }}">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                </div>
                <ol class="list-decimal list-inside text-sm text-neutral-600 space-y-1.5">
                    <li>{{ t('payment.step_1') }}</li>
                    <li>{{ t('payment.step_2') }}</li>
                    <li>{{ t('payment.step_3') }}</li>
                </ol>
                {% include '_bank_details.twig' with { reference: null } %}
                <button type="button" @click="payOpen = false"
                        class="w-full rounded-lg bg-neutral-900 text-white py-2.5 font-semibold hover:bg-neutral-700">
                    {{ t('payment.modal_close') }}
                </button>
            </div>
        </div>
    </div>
{% endblock %}
