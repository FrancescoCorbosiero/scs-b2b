{% extends 'layout.twig' %}

{% block title %}{{ t('order.confirmation_title') }} — {{ t('app.title') }}{% endblock %}

{% block content %}
    <div class="max-w-lg mx-auto mt-10 text-center">
        <div class="mx-auto w-16 h-16 rounded-full bg-emerald-100 flex items-center justify-center mb-5">
            <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
        </div>
        <h1 class="text-2xl font-bold mb-2">{{ t('order.confirmation_title') }}</h1>
        <p class="text-neutral-600 mb-8">{{ t('order.confirmation_text', {id: order_id}) }}</p>

        <div class="bg-white rounded-xl border border-neutral-200 p-5 text-left">
            <h2 class="font-semibold mb-3">{{ t('order.confirmation_contacts') }}</h2>
            <ul class="space-y-2 text-sm">
                <li><span class="text-neutral-500">{{ t('contact.email') }}:</span> <a class="underline" href="mailto:{{ contact.email }}">{{ contact.email }}</a></li>
                <li><span class="text-neutral-500">{{ t('contact.phone') }}:</span> <a class="underline" href="tel:{{ contact.phone|replace({' ': ''}) }}">{{ contact.phone }}</a></li>
                {% if contact.whatsapp_link %}
                    <li><span class="text-neutral-500">{{ t('contact.whatsapp') }}:</span> <a class="underline" href="{{ contact.whatsapp_link }}" rel="noopener">{{ contact.whatsapp }}</a></li>
                {% endif %}
            </ul>
        </div>

        <a href="/" class="inline-block mt-8 rounded-lg bg-neutral-900 text-white px-5 py-2.5 font-semibold hover:bg-neutral-700">{{ t('error.back_home') }}</a>
    </div>
{% endblock %}
