{
    "name": "scs-b2b-assets",
    "private": true,
    "description": "Build asset (Tailwind + Alpine) — Node solo in build, mai in runtime",
    "scripts": {
        "build": "tailwindcss -i assets/css/app.css -o public/assets/app.css --minify && node scripts/copy-js.mjs",
        "watch": "tailwindcss -i assets/css/app.css -o public/assets/app.css --watch"
    },
    "devDependencies": {
        "alpinejs": "^3.14.0",
        "tailwindcss": "^3.4.0",
        "@tailwindcss/forms": "^0.5.7"
    }
}
