# ── App ──────────────────────────────────────────────────────────────
APP_ENV=production                # production | development
APP_URL=https://b2b.shoesclothingstore.com
APP_TIMEZONE=Europe/Rome

# ── Database (docker compose usa questi stessi valori) ───────────────
DB_DRIVER=mysql                   # mysql | sqlite (sqlite SOLO per sviluppo/test senza Docker)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=b2b_catalog
DB_USER=b2b
DB_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me-root  # usato solo dal container mysql

# ── Autenticazione ───────────────────────────────────────────────────
# Genera gli hash con: php bin/hash-password.php "la-password"
# ⚠ IMPORTANTE: racchiudi gli hash tra APICI SINGOLI — contengono "$" che
#   Docker Compose altrimenti interpola come variabili, mutilando l'hash.
#   Es: CATALOG_PASSWORD_HASH='$argon2id$v=19$m=65536,...'
#   Vale per QUALSIASI valore contenente "$" (anche DB/SMTP password).
CATALOG_PASSWORD_HASH=
ADMIN_PASSWORD_HASH=
SESSION_LIFETIME_DAYS=7
# Subnet fidate per X-Forwarded-For (helper PHP; nginx fa già set_real_ip_from).
# Vuoto = usa sempre REMOTE_ADDR. Es: TRUSTED_PROXY_SUBNETS=172.18.0.0/16
TRUSTED_PROXY_SUBNETS=

# ── Feed GoldenSneakers ──────────────────────────────────────────────
FEED_SOURCE=fixture               # fixture | live  (fixture finché manca il token)
FEED_BASE_URL=https://www.goldensneakers.net
FEED_ENDPOINT=/api/assortment-flat/
FEED_BEARER_TOKEN=                # riservato: mai committare
FEED_FIXTURE_PATH=fixtures/goldensneakers-dev.json  # usata con FEED_SOURCE=fixture
FEED_SYNC_INTERVAL=7200           # secondi tra i sync del cron (default 2h)
FEED_HTTP_TIMEOUT=60
IMAGE_CACHE_LOCAL=0               # 1 = scarica e serve le immagini in locale (previsto, non attivo in v1)

# ── Ordini dropship GoldenSneakers (ANTEPRIMA — vedi docs/09) ────────
# Crea l'ordine direttamente presso il fornitore (dominio "order-dropship"
# dell'API), così lo stock GoldenSneakers resta allineato.
# ⚠ Con DROPSHIP_MODE=simulation NESSUNA chiamata parte: il flusso viene
#   solo registrato e mostrato come SIMULAZIONE. La modalità live NON è
#   ancora implementata (il client la rifiuta): attivarla richiede di
#   completare GoldenSneakersDropshipClient e validare gli endpoint su
#   Swagger col bearer token del feed.
DROPSHIP_ENABLED=1                # 1 = mostra la sezione in /admin
DROPSHIP_MODE=simulation          # simulation | live (live non implementato)
DROPSHIP_CREATE_ENDPOINT=/api/orders-dropship/create/          # da verificare su Swagger
DROPSHIP_DETAILS_ENDPOINT=/api/orders-dropship/order-details/  # da verificare su Swagger

# ── Pricing (piani) ──────────────────────────────────────────────────
# ⚠ Percentuali placeholder: confermare i valori reali (docs/08 § domande aperte)
MARKUP_BASE=30
MARKUP_PRO=25
MARKUP_MAX=20
VAT_PERCENTAGE=22
PRICE_ROUNDING=whole              # whole | half | none

# ── Regole catalogo ──────────────────────────────────────────────────
MIN_ORDER_ITEMS=5
AVAILABILITY_HIGH_MIN=60          # pezzi totali per "Alta disponibilità"
AVAILABILITY_LOW_MAX=20           # pezzi totali per "Bassa disponibilità"
PRODUCTS_PER_PAGE=24

# ── Email ────────────────────────────────────────────────────────────
# AWS SES (endpoint SMTP, consigliato — vedi README § Email via AWS SES):
#   SMTP_HOST=email-smtp.eu-south-1.amazonaws.com   (Milano; o eu-central-1, ecc.)
#   SMTP_PORT=587
#   SMTP_USER=<SES SMTP username>       ⚠ credenziali SMTP dedicate, NON l'access key IAM
#   SMTP_PASSWORD='<SES SMTP password>' ⚠ apici singoli se contiene "$"
#   SMTP_ENCRYPTION=tls
# MAIL_FROM_ADDRESS deve essere un'identità VERIFICATA in SES (dominio o indirizzo).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls               # tls | ssl
MAIL_FROM_ADDRESS=noreply@shoesclothingstore.com
MAIL_FROM_NAME="SHOES & CLOTHING RESELLING"
ADMIN_EMAIL=info@shoesclothingstore.com
ADMIN_EMAIL_SHOW_COST=1           # include costo fornitore e margine nell'email admin

# ── Contatti pubblici (pagina /contatti) ─────────────────────────────
CONTACT_COMPANY_NAME="SHOES & CLOTHING RESELLING OFFICIAL STORE"
CONTACT_EMAIL=shoes.clothing_reselling@yahoo.com
CONTACT_PHONE="+39 380 477 8879"
CONTACT_WHATSAPP="+393297720691"
CONTACT_ADDRESS="Via Paolo Ricci 12/a, 76121 Barletta (BT)"
CONTACT_VAT="P.IVA 091460600729"
MAIN_SITE_URL=https://shoesclothingstore.com/
