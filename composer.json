{
    "name": "scs/b2b-catalog",
    "description": "Catalogo sneakers B2B — b2b.shoesclothingstore.com",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "ext-curl": "*",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-zip": "*",
        "dompdf/dompdf": "^3.1",
        "monolog/monolog": "^3.7",
        "php-di/php-di": "^7.0",
        "phpmailer/phpmailer": "^6.9",
        "slim/psr7": "^1.7",
        "slim/slim": "^4.14",
        "twig/twig": "^3.14",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.3.6"
        },
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse"
    }
}
